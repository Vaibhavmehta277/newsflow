# ============================================================
# NewsFlow — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Restrict login to your company domain (optional)
# ALLOWED_EMAIL_DOMAIN=smallest.ai

# ============================================================
# Google OAuth (for team login via NextAuth)
# Create at: console.cloud.google.com → APIs & Services → Credentials
# Add redirect URI: http://localhost:3000/api/auth/callback/google
# ============================================================
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# ============================================================
# Google Service Account (for Sheets API)
# Create at: console.cloud.google.com → IAM & Admin → Service Accounts
# Download JSON key and extract these fields
# Share your Google Sheet with the service account email
# ============================================================
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_PRIVATE_KEY_ID=your-private-key-id
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nyour-key-here\n-----END RSA PRIVATE KEY-----"
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_CLIENT_ID=your-service-account-client-id

# Google Sheet ID (from the URL: docs.google.com/spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_ID=your-google-sheet-id

# ============================================================
# Anthropic Claude API (for caption generation)
# Get at: console.anthropic.com
# ============================================================
ANTHROPIC_API_KEY=sk-ant-your-key-here
